{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/api.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "start:api": "node dist/api.js",
    "start:processor": "node dist/processor.js",
    "dev": "node scripts/dev.js",
    "dev:db": "docker compose up -d db",
    "dev:api": "ts-node-dev --respawn --transpile-only src/api.ts",
    "dev:processor": "ts-node-dev --respawn --transpile-only src/processor.ts",
    "stop:db": "docker compose down",
    "migration:run": "npm run build && npm run dev:db && typeorm migration:run -d dist/infrastructure/db/data-source.js",
    "migration:generate": "npm run dev:db && npm run build && typeorm migration:generate dist/infrastructure/db/migrations/AutoMigration -d dist/infrastructure/db/data-source.js",
    "migration:run:prod": "npm run build && typeorm migration:run -d dist/infrastructure/db/data-source.js",
    "test": "vitest run --environment node --globals --pool threads --exclude dist/**"
  },
  "keywords": [],
  "author": "Damilola Saliu",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/vertexai": "^1.12.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.28",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0"
  }
}
